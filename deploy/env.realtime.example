# /etc/onlinetest/realtime.env — huquq 600
REALTIME_PORT=9082
REALTIME_BIND=127.0.0.1
NODE_ENV=production
SOCKET_IO_CORS_ORIGIN=https://onlinetest.ziyrak.org

# API bilan bir xil JWT imzo kaliti (api.env dagi JWT_SECRET ni shu yerga ham qo‘ying).
# Qo‘yilmasa, NODE_ENV=production da ulanishlar tekshiruvsiz qoladi (xavf).
JWT_SECRET=
