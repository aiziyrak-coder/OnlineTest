# /etc/onlinetest/api.env — fayl huqufi: root:root 600
# Parollarni chatga yozmang; kalitlarni faqat serverda yarating.
#
# HTTPS (ikki domen: frontend + API): barcha URL lar https://; CORS da faqat frontend domeni.
# TLS ni nginx bajaradi — DJANGO_SECURE_SSL=1 qo‘ymang (redirect loop).
# Certbot: sudo bash deploy/https-certbot.sh FRONT_DOMEN API_DOMEN

DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
# PostgreSQL (prod uchun tavsiya):
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/onlinetest
#
# Agar hali PostgreSQL yo‘q va mavjud SQLite (/var/www/.../db.sqlite3) bilan ishlayapsiz — bittasini qo‘shing:
# DATABASE_ALLOW_SQLITE_PROD=1
# Keyinroq: Postgres ga migrate qilib, bu qatorni olib tashlang.
# DB_CONN_MAX_AGE=60
# DATABASE_SSL_REQUIRE=1
APP_BUILD_REF=
# API tinglash (systemd unitda ham GUNICORN_BIND beriladi; bu yerda qayta yozmaslik mumkin)
# GUNICORN_BIND=127.0.0.1:9081
# Nginx: proxy_set_header Host $host; bo‘lsa va domen ishonchli bo‘lsa
# TRUST_X_FORWARDED_HOST=1
# LOG_JSON=1
# API alohida domen: DNS da api A yozuvi; nginx deploy/nginx/onlinetest.conf da api server_name bor.
ALLOWED_HOSTS=api.online-imtixon.uz,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://online-imtixon.uz,https://api.online-imtixon.uz
# CORS dagi domenlar settings.py da CSRF_TRUSTED_ORIGINS ga ham qo‘shiladi (fayl yuklash POST 403).
CORS_ALLOWED_ORIGINS=https://online-imtixon.uz
# Frontend to‘g‘ridan-to‘g‘ri API domeniga murojaat qilsa: VITE_API_BASE_URL=https://api.online-imtixon.uz

JWT_SECRET=

# Bir martalik superadmin (AppUser, role=admin): sudo bash deploy/ensure-superadmin.sh
# (api.env da SUPERADMIN_PASSWORD bo‘lishi kerak; parolni chatga yozmang)
SUPERADMIN_PASSWORD=
# SUPERADMIN_ID=superadmin

# bootstrap_exam: prod da ADMIN_BOOTSTRAP_PASSWORD majburiy (kamida 12 belgi). bootstrap-ubuntu-once.sh avto yaratadi.
# ADMIN_BOOTSTRAP_ID=fjstiadmin
# ADMIN_BOOTSTRAP_PASSWORD=

# Bir martalik demo loginlar: python manage.py seed_demo_users
# DEBUG=0: DEMO_SEED_PASSWORD majburiy (≥12). Keyin o‘chiring yoki parolni almashtiring.
# DEMO_SEED_PASSWORD=

# JWT muddati (soat, 1–168, standart 24)
# JWT_EXPIRE_HOURS=24

PUBLIC_APP_URL=https://online-imtixon.uz
# TLS nginx da; Django ichki HTTP — SSL redirect Django da yoqilmasin (loop bo‘lishi mumkin).
SECURE_PROXY_SSL_HEADER=X-Forwarded-Proto:https

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
