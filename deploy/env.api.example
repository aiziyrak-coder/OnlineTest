# /etc/onlinetest/api.env — fayl huqufi: root:root 600
# Parollarni chatga yozmang; kalitlarni faqat serverda yarating.

DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
ALLOWED_HOSTS=onlinetestapi.ziyrak.org,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://onlinetest.ziyrak.org,https://onlinetestapi.ziyrak.org
CORS_ALLOWED_ORIGINS=https://onlinetest.ziyrak.org

JWT_SECRET=

PUBLIC_APP_URL=https://onlinetest.ziyrak.org
DJANGO_SECURE_SSL=1
SECURE_PROXY_SSL_HEADER=X-Forwarded-Proto:https

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
