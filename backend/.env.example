# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
ALLOWED_HOSTS=127.0.0.1,localhost
# Prod: HTTPS orqali
# DJANGO_SECURE_SSL=1
# SECURE_PROXY_SSL_HEADER=X-Forwarded-Proto:https
# CSRF_TRUSTED_ORIGINS=https://app.example.com

JWT_SECRET=

# JWT amal qilish muddati (soat, 1–168)
# JWT_EXPIRE_HOURS=24

CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Ijtimoiy havola / sertifikat tekshiruvi (frontend domeni)
PUBLIC_APP_URL=

# Gemini (ixtiyoriy: yuz, AI savollar, xulosa)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Bir martalik admin (bootstrap_exam): standart fjstiadmin / fjsti123
# ADMIN_BOOTSTRAP_ID=fjstiadmin
# ADMIN_BOOTSTRAP_PASSWORD=fjsti123

# Socket.IO realtime (Node server) — JWT_SECRET shu yerga ham (Django bilan bir xil) bo‘lishi kerak
# SOCKET_IO_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
# REALTIME_PORT=3001
# JWT_SECRET=  (yuqoridagi bilan bir xil)
