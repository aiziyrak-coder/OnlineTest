# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (production). Bo‘sh qoldirilsa — SQLite (faqat dev).
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# DB_CONN_MAX_AGE=60
# DATABASE_SSL_REQUIRE=1
# Prod: HTTPS orqali
# DJANGO_SECURE_SSL=1
# SECURE_PROXY_SSL_HEADER=X-Forwarded-Proto:https
# CSRF_TRUSTED_ORIGINS=https://app.example.com

JWT_SECRET=

# JWT amal qilish muddati (soat, 1–168)
# JWT_EXPIRE_HOURS=24

CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Ijtimoiy havola / sertifikat tekshiruvi (frontend domeni)
PUBLIC_APP_URL=

# Gemini (ixtiyoriy: yuz, AI savollar, xulosa)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# API build/reviziya (ixtiyoriy, /api/health, /api/live, /api/ready da ko‘rinadi)
# APP_BUILD_REF=v1.2.3
# CI: GIT_COMMIT yoki APP_BUILD_REF

# Nginx orqasida to‘g‘ri Host (faqat ishonchli proxyda yoqing)
# TRUST_X_FORWARDED_HOST=1

# Prod loglar: JSON qator (Loki / journald)
# LOG_JSON=1

# Bir martalik admin (bootstrap_exam). DJANGO_DEBUG=0 bo‘lsa: ADMIN_BOOTSTRAP_PASSWORD majburiy, kamida 12 belgi.
# DJANGO_DEBUG=1 (mahalliy): parol ixtiyoriy; berilmasa standart fjsti123 ishlatiladi.
# ADMIN_BOOTSTRAP_ID=fjstiadmin
# ADMIN_BOOTSTRAP_PASSWORD=o‘zingizning-kuchli-parolingiz-min-12

# seed_demo_users: demo_admin / demo_student / demo_teacher uchun umumiy parol.
# DEBUG=0: majburiy, ≥12 belgi. DEBUG=1: ixtiyoriy; bo‘sh bo‘lsa DemoFJSTI2026!
# DEMO_SEED_PASSWORD=

# Socket.IO realtime (Node server) — JWT_SECRET shu yerga ham (Django bilan bir xil) bo‘lishi kerak
# SOCKET_IO_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
# REALTIME_PORT=3001
# JWT_SECRET=  (yuqoridagi bilan bir xil)
