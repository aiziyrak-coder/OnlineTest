# Build: npm run build (faqat https:// — brauzer mixed-content bloklaydi)
# API va Socket.IO bir xil domen (nginx: /api/ va /socket.io/).
# api A yozuvi DNS da bo‘lmasa — asosiy domen (nginx apex server blokida proxy bor):
#   VITE_API_BASE_URL=http://online-imtixon.uz
#   VITE_SOCKET_URL=http://online-imtixon.uz
# DNS tayyor bo‘lsa:
VITE_API_BASE_URL=https://api.online-imtixon.uz
VITE_SOCKET_URL=https://api.online-imtixon.uz
