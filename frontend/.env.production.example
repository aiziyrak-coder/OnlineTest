# Production build: npm ci && npm run build
#
# Tavsiya — bitta domen (api DNS shart emas). Bo‘sh qoldiring: API va Socket.IO
# joriy sahifa manziliga nisbiy (/api/, /socket.io/) — nginx apex blokida proxy bor.
VITE_API_BASE_URL=
VITE_SOCKET_URL=
#
# Alohida API domeni faqat DNS da api A yozuvi bor va sertifikat tayyor bo‘lgach:
# VITE_API_BASE_URL=https://api.online-imtixon.uz
# VITE_SOCKET_URL=https://api.online-imtixon.uz
#
# HTTP-only apex (https emas): aniq yozing, bo‘sh qoldirmang:
# VITE_API_BASE_URL=http://online-imtixon.uz
# VITE_SOCKET_URL=http://online-imtixon.uz
