# Ishlab chiqish: Vite /api ni backend ga proxylaydi (vite.config.ts)
# Production build: to‘liq URL (CORS backendda yoqilgan bo‘lishi kerak)
# VITE_API_BASE_URL=https://api.sizning-domen.uz

# Socket.IO (proctoring) — alohida Node realtime server
# VITE_SOCKET_URL=http://127.0.0.1:3001

# Backend proxy maqsadi (faqat npm run dev)
# VITE_PROXY_API=http://127.0.0.1:8000

# Virtual kamera (OBS va h.k.) lab testida yoqilsin — prod build da yozilmaydi (VAC xavfsizlik).
# VITE_ALLOW_VIRTUAL_CAMERA=true
