# Server (nusxalang: .env)
NODE_ENV=development
PORT=3000

# --- Majburiy (production) ---
# Kamida 24 belgi, tasodifiy; default qiymat bilan ishga tushmaydi
# JWT_SECRET=

# Birinchi marta bo‘sh bazada admin yaratish (faqat production, min 12 belgi).
# Muvaffaqiyatli deploydan keyin .env dan olib tashlang.
# ADMIN_BOOTSTRAP_PASSWORD=

# Agar reverse proxy (nginx) orqasida bo‘lsa: rate limit va IP to‘g‘ri ishlashi uchun
# TRUST_PROXY=1

# Tashqi URL (QR va PDF havlolari uchun); bo‘lmasa so‘rov Host sarlavhasidan olinadi
# PUBLIC_APP_URL=https://imtihon.sizning-domen.uz

# Gemini (yuz tekshiruvi, test bazasi+AI, natija xulosasi)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Socket.IO: productionda aniq domenlar (vergul bilan). Bo‘lmasa * (xavfli).
# SOCKET_IO_CORS_ORIGIN=https://app.example.com

# Development: mock imtihonlar / demo talaba — o‘chirish
# DISABLE_MOCK_SEED=1

# Proctor warning boshqaruvi:
# Bir xil daqiqadagi ko'p xatoni 1 rasmiy ogohlantirishga birlashtirish oynasi (sekund)
# PROCTOR_WARN_SUPPRESS_SECONDS=60
# Imtihon boshidagi texnik "false positive" larni suppress qilish (sekund, violation yozilmasin)
# PROCTOR_STARTUP_GRACE_SECONDS=40
# Agressiv anti-cheat: rolling risk-score; boshlang'ich 60s ichida hard-ban hisobi o'chiriladi
# PROCTOR_HARDENED_MODE=1
# PROCTOR_HARDENED_STARTUP_GRACE_SECONDS=60
# PROCTOR_HARD_WINDOW_MIN=10
# PROCTOR_HARD_MAX_POINTS=14
# VAC strict: faqat IDENTITY_SUBSTITUTION darhol ban; qolganlari ogohlantirish ketma-ketligi
# VAC_STRICT_MODE=1
# Faqat kompyuter qurilmadan imtihon boshlash (mobile/tablet block)
# VAC_PC_ONLY=1
# Bir talaba imtihon sessiyasi bitta qurilmaga lock bo'ladi (fingerprint talab qilinadi)
# VAC_DEVICE_LOCK=1
# Request imzolash (HMAC + nonce anti-replay) — yoqsangiz front va backend birga ishlashi shart
# VAC_HMAC_GUARD=1
# Request sequence chain (strict request ordering)
# VAC_SEQ_GUARD=1
# One-time challenge chain (seq bilan birga ishlatish tavsiya)
# VAC_CHALLENGE_GUARD=1
# VAC_HMAC_MAX_DRIFT_SEC=90

# Production: mock ma’lumot va demo `student` foydalanuvchisini majburan yoqish (faqat staging)
# ENABLE_MOCK_SEED=1

# Vite HMR (Express bilan bir portda muammo bo‘lsa)
# DISABLE_HMR=true
